// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  // Onboarding
  ageVerified         Boolean @default(false)
  budgetLimit         Float?
  timeLimit           Int?
  preferredActivities String?

  // Mental health check-in
  onboardingMood       String? // "great" | "good" | "okay" | "not_great"
  onboardingStress     String? // "low" | "moderate" | "high" | "very_high"
  onboardingIntent     String? // "fun" | "celebrating" | "bored" | "escaping"
  baselineRiskModifier Int     @default(0)

  // Behavioral stats
  totalSessions      Int      @default(0)
  avgSessionDuration Float    @default(0)
  avgRiskScore       Float    @default(0)
  aceInterventions   Int      @default(0)
  aceAccepted        Int      @default(0)
  lastSessionAt      DateTime?

  sessions Session[]
}

model Session {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  duration      Int?
  peakRiskScore Float     @default(0)
  finalBankroll Float?
  aceTriggered  Boolean   @default(false)
  userAccepted  Boolean   @default(false)
}
